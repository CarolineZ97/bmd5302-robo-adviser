# Copy this file to .env and fill in your API key
# The chatbot is OpenAI-compatible. Works with DeepSeek / Qwen / OpenAI / Ollama.
#
# --- Example 1: DeepSeek (cheap, recommended) ---
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
#
# --- Example 2: Qwen (Alibaba) ---
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
#
# --- Example 3: OpenAI ---
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
#
# If left empty, the chatbot falls back to a rule-based Mock LLM (still fully runnable for demo).

OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=
