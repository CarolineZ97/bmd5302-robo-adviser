# Streamlit Cloud Secrets 模板
#
# 本文件只是示例。真实的 secrets 不要提交到 git，而是：
#   1. 在 Streamlit Cloud 网页控制台 → App → Settings → Secrets 中粘贴。
#   2. 或者本地开发时，复制为 .streamlit/secrets.toml（已在 .gitignore 中排除）。
#
# 以下键会被 config.py 的 _read_secret() 自动读取，
# 优先级：OS 环境变量 > st.secrets > 默认值。

# === LLM 配置（OpenAI 兼容协议） ===================================
# DeepSeek 官方（推荐，¥1/百万 tokens，注册送免费额度）
OPENAI_API_KEY = "sk-xxxxxxxxxxxxxxxxxxxxxxxx"
OPENAI_BASE_URL = "https://api.deepseek.com/v1"
LLM_MODEL = "deepseek-chat"

# 其他可选端点（解除注释即可切换）：
# --- OpenAI 官方 ---
# OPENAI_API_KEY = "sk-..."
# OPENAI_BASE_URL = "https://api.openai.com/v1"
# LLM_MODEL = "gpt-4o-mini"

# --- 阿里通义千问 ---
# OPENAI_API_KEY = "sk-..."
# OPENAI_BASE_URL = "https://dashscope.aliyuncs.com/compatible-mode/v1"
# LLM_MODEL = "qwen-plus"

# --- Moonshot Kimi ---
# OPENAI_API_KEY = "sk-..."
# OPENAI_BASE_URL = "https://api.moonshot.cn/v1"
# LLM_MODEL = "moonshot-v1-8k"
